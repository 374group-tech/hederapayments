# Hedera Testnet (ED25519 private key in DER format)
HEDERA_OPERATOR_ID=0.0.YOUR_ACCOUNT_ID
HEDERA_OPERATOR_KEY=YOUR_DER_PRIVATE_KEY

# DeepSeek API (free tier, https://platform.deepseek.com)
# This is also used as the Pioneer API key when baseURL is api.pioneer.ai/v1
DEEPSEEK_API_KEY=sk-your-key

# ── Policy Configuration (optional — defaults shown) ──

# SpendLimitPolicy: daily HBAR cap
DAILY_SPEND_LIMIT_HBAR=5
MAX_PER_TX_HBAR=2

# TimeWindowPolicy: business hours only (UTC)
BUSINESS_START_HOUR=9
BUSINESS_END_HOUR=18

# ServiceAllowPolicy: comma-separated whitelist
ALLOWED_SERVICES=tavily,openai,hedera

# Tavily search (for agent web queries)
TAVILY_API_KEY=tvly-your-key

# Telegram alerts (optional — AlertHook fires on blocks/high-value tx)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# HCS audit topic (auto-created if empty, persisted across restarts)
HCS_AUDIT_TOPIC_ID=
