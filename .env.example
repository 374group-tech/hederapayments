# Hedera Testnet (ED25519 account that signs transactions)
HEDERA_OPERATOR_ID=0.0.9253164
HEDERA_OPERATOR_KEY=302e...

# DeepSeek API (free tier at platform.deepseek.com)
DEEPSEEK_API_KEY=sk-...

# ── Policy Configuration (optional — defaults shown) ──

# SpendLimitPolicy
DAILY_SPEND_LIMIT_HBAR=5
MAX_PER_TX_HBAR=2

# TimeWindowPolicy
BUSINESS_START_HOUR=9
BUSINESS_END_HOUR=18

# ServiceAllowPolicy (comma-separated)
ALLOWED_SERVICES=tavily,openai,hedera

# MaxSpendPolicy (USD-based budgeting)
MAX_SPEND_USD_DAILY=500
HBAR_USD_RATE=0.07

# AllowlistPolicy (comma-separated account IDs + API providers)
ALLOWED_ACCOUNT_IDS=0.0.12345,0.0.67890
ALLOWED_API_PROVIDERS=openai,tavily,hedera

# Tavily (web search API)
TAVILY_API_KEY=tvly-...

# Telegram Bot (for AlertHook notifications)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# HCS Audit Trail (auto-created on first use, persisted here across restarts)
HCS_AUDIT_TOPIC_ID=
